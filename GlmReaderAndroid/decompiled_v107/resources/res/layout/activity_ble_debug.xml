<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:id="@+id/toolbar"
        android:background="@color/toolbar_background"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/statusBar"
        android:background="#1a1a1a"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ff5252"
            android:id="@+id/tvConnStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Не подключено"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffc107"
            android:id="@+id/tvState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="State: ---"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4caf50"
            android:id="@+id/tvQueue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q:0"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:background="#151515"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <TextView
            android:textSize="12sp"
            android:textColor="#4fc3f7"
            android:id="@+id/tvRx"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="RX: 0 B"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#81c784"
            android:id="@+id/tvTx"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="TX: 0 B"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#ffb74d"
            android:id="@+id/tvMeasurements"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M: 0"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <EditText
            android:textSize="13sp"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:id="@+id/etRawCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="HEX: C0 55 02 40 00"
            android:maxLines="1"
            android:layout_weight="1"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"/>
        <Button
            android:textSize="12sp"
            android:id="@+id/btnSendRaw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>
    <HorizontalScrollView
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:textSize="11sp"
                android:id="@+id/btnInit"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Init"/>
            <Button
                android:textSize="11sp"
                android:id="@+id/btnTrigger"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trigger"/>
            <Button
                android:textSize="11sp"
                android:id="@+id/btnGetSettings"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GetSet"/>
            <Button
                android:textSize="11sp"
                android:id="@+id/btnClearLog"
                android:padding="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear Log"/>
        </LinearLayout>
    </HorizontalScrollView>
    <TextView
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:paddingBottom="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LOG:"
        android:paddingStart="8dp"/>
    <ScrollView
        android:id="@+id/scrollLog"
        android:background="#0d0d0d"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">
        <TextView
            android:textSize="11sp"
            android:textColor="#e0e0e0"
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BLE Debug ready...\10"
            android:fontFamily="monospace"/>
    </ScrollView>
</LinearLayout>
