<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Тема с поддержкой DayNight (светлая/темная) -->
    <style name="Base.Theme.GlmReaderAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2B5878</item>
        <item name="colorPrimaryDark">#1A3A5C</item>
        <item name="colorAccent">#0091EA</item>
        <!-- Цвет текста popup меню по умолчанию - темный для светлой темы -->
        <item name="android:textColorPrimary">#212121</item>
        <item name="popupMenuBackground">@color/popup_background</item>
        <!-- Цвет текста элементов popup меню -->
        <item name="android:itemTextAppearance">@style/PopupMenuTextAppearance</item>
    </style>

    <style name="PopupMenuTextAppearance" parent="android:TextAppearance">
        <item name="android:textColor">#212121</item>
    </style>

    <style name="Theme.GlmReaderAndroid" parent="Base.Theme.GlmReaderAndroid" />
</resources>
