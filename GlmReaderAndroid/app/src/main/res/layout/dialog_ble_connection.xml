<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Статус Bluetooth -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvBleStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bluetooth выключен"
            android:textColor="@color/status_error"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnToggleBle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Включить"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Заголовок списка -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Доступные устройства"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Список устройств -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDevices"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="?android:attr/colorBackground"
        android:layout_marginBottom="12dp" />

    <!-- Кнопки управления -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сканировать"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Подключить"
            android:enabled="false" />
    </LinearLayout>

    <!-- Статус подключения -->
    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Не подключено"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary" />

    <!-- Кнопка забыть -->
    <Button
        android:id="@+id/btnForget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Забыть устройство"
        android:enabled="false"
        android:layout_marginTop="8dp"
        style="?android:attr/buttonBarButtonStyle" />

</LinearLayout>
