<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <!-- Корзина (удалить) -->
    <ImageView
        android:id="@+id/ivTrash"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        android:contentDescription="Удалить"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#2B5878" />

    <!-- Информация (название + дата) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#1A3A5C"
            android:textSize="16sp"
            tools:text="Д-11 П3.2.1-2.Кл7" />

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#888888"
            android:textSize="13sp"
            tools:text="25.03.2026 20:56" />
    </LinearLayout>

    <!-- Значение справа -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <!-- Иконка типа замера (зависит от devMode) -->
        <ImageView
            android:id="@+id/ivTypeIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Тип замера"
            android:src="@drawable/ic_distance"
            android:tint="#0091EA" />

        <!-- Значение синим как в MM -->
        <TextView
            android:id="@+id/tvValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0091EA"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="1033,1 mm" />

        <!-- Стрелка раскрывающегося списка (для составных замеров) -->
        <TextView
            android:id="@+id/tvArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="∨"
            android:textColor="#2B5878"
            android:textSize="16sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- Разделитель снизу (с отступом от корзины) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="46dp"
        android:background="#e0e0e0" />

    <!-- Чекбокс для Selection Mode -->
    <CheckBox
        android:id="@+id/cbSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

</LinearLayout>
